    margin-top: 10px;
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #333;
    text-align: center;
    transition: color 0.2s ease;
}

.katSliderBlock ul li:hover a span {
    color: var(--theme-color); /* Hover durumunda yazıyı turuncu yapar */
}

