/* ASAF GASTRO - 2. EL SAYFASI ÖZEL TASARIMI (GÜNCEL)      */
/* ======================================================= */

..asaf-2el-container {
    font-family: 'Mulish', sans-serif;
    width: 100% !important;
    max-width: 1200px !important;
    margin-left: auto !important; /* Temanın sola yaslamasını ezer */
    margin-right: auto !important; /* Temanın sağdaki boşluğunu ezer */
    margin-top: 40px;
    margin-bottom: 40px;
    padding: 0 15px;
    color: #333;
    box-sizing: border-box;
    overflow: hidden;
    display: block !important; /* Kapsayıcının tam blok olarak davranmasını zorunlu kılar */
    clear: both !important; /* Eğer üstte float kullanan bir element varsa onu temizler */
}

.asaf-2el-container * {
    box-sizing: border-box;
}

.asaf-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center; /* Dikey ortalama */
    justify-content: center; /* YENİ EKLENDİ: İçerikleri yatay eksende ortalar */
    gap: 40px;
    margin-bottom: 60px;
}

.asaf-row-reverse {
    flex-direction: row-reverse;
}

.asaf-col-img {
    flex: 1 1 45%;
    min-width: 300px;
    text-align: center;
}

.asaf-col-img img {
    width: 100%;
    max-width: 580px;
    height: auto;
    aspect-ratio: 58 / 48;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    display: block;
    margin: 0 auto; /* Resmi kendi sütunu içinde ortalar */
}

.asaf-col-text {
    flex: 1 1 45%;
    min-width: 300px;
}

.asaf-title {
    font-size: 32px;
    font-weight: 700;
    color: #ef7c00; 
    margin-top: 0;
    margin-bottom: 20px;
    line-height: 1.3;
}

.asaf-desc {
    font-size: 15px;
    line-height: 1.8;
    color: #555;
    margin-bottom: 20px;
}

.asaf-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 25px;
}

.asaf-tag {
    background: #fff7f0;
    color: #ef7c00;
    border: 1px solid #ef7c00;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
}

.asaf-features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 30px;
}

.asaf-feature-card {
    background: #fafafa;
    padding: 20px;
    border-radius: 8px;
    border-left: 4px solid #ef7c00;
    transition: transform 0.3s ease;
}

.asaf-feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.asaf-feature-card h4 {
    margin: 0 0 10px 0;
    font-size: 16px;
    color: #222;
    font-weight: 700;
}

.asaf-feature-card p {
    margin: 0;
    font-size: 13px;
    color: #666;
    line-height: 1.6;
}

.asaf-seo-box {
    background: #fff;
    border: 1px solid #eee;
    padding: 15px 20px;
    border-radius: 8px;
    margin-bottom: 15px;
    font-size: 14px;
    color: #555;
    line-height: 1.6;
    position: relative;
    padding-left: 40px;
}

.asaf-seo-box::before {
    content: "✓";
    font-family: 'Mulish', sans-serif;
    position: absolute;
    left: 15px;
    top: 15px;
    color: #ef7c00;
    font-weight: bold;
}

@media (max-width: 991px) {
    .asaf-row, .asaf-row-reverse {
        flex-direction: column !important;
        align-items: center !important; /* YENİ EKLENDİ: Sütunları alt alta girdiği zaman merkeze hizalar */
        gap: 20px !important;
        margin-bottom: 50px !important;
    }
    .asaf-col-img, .asaf-col-text {
        width: 100% !important;
        min-width: 100% !important;
        flex: 0 0 100% !important;
    }
    .asaf-title {
        font-size: 24px !important;
        text-align: center !important;
    }
    .asaf-desc {
        text-align: center !important;
    }
    .asaf-tags {
        justify-content: center !important;
    }
    .asaf-features-grid {
        grid-template-columns: 1fr !important;
    }
}
