/* ==========================================================================
   ASAF GASTRO - HİYERARŞİK BLOK CSS
   Sıralama: slider → populer-kategoriler → yaz-ekipmanlari → yaz-vitrin
             → kategori-blok → gorkem-vitrin-ust-banner → gorkem-vitrin
   ========================================================================== */


/* ============================================================
   1. ASAF-SLIDER-BLOK
   ============================================================ */

.asaf-slider-blok {
    width: 100% !important;
    margin: 20px auto 20px auto !important;
    clear: both !important;
    float: left !important;
}

.asaf-grid-container {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    display: flex;
    flex-flow: row wrap;
    justify-content: space-between;
    box-sizing: border-box;
}

.asaf-grid-col-left {
    width: 680px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.asaf-grid-col-right {
    width: 480px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.asaf-slider-card { height: 340px; position: relative; }
.asaf-medium-banner { height: 180px; position: relative; }
.asaf-large-banner { height: 260px; position: relative; }

.asaf-grid-card {
    background: #ffffff !important;
    border-radius: 16px !important;
    border: 1px solid #eeeff0 !important;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.05) !important;
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease !important;
}

.asaf-grid-card:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.1) !important;
    border-color: #ef7c00 !important;
}

.asaf-slider-card a {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
}

.asaf-grid-card:not(.asaf-slider-card) a {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    z-index: 99 !important;
    display: block !important;
}

.asaf-grid-card img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block !important;
}

.asaf-slider-blok .owl-dots,
.asaf-grid-slider .owl-dots {
    display: none !important;
    opacity: 0 !important;
    visibility: hidden !important;
    height: 0 !important;
    margin: 0 !important;
}

@media screen and (max-width: 1041px) {
    .asaf-slider-blok {
        margin: 0 auto 20px auto !important;
    }

    .asaf-grid-container {
        padding: 0 10px !important;
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: wrap !important;
        justify-content: space-between !important;
        gap: 10px !important;
    }

    .asaf-grid-col-left,
    .asaf-grid-col-right {
        display: contents !important;
    }

    .asaf-grid-card *,
    .asaf-grid-card span,
    .asaf-grid-card p,
    .asaf-grid-card h3 {
        font-size: 0 !important;
        color: transparent !important;
    }

    .asaf-grid-card:not(.asaf-slider-card) a {
        position: absolute !important;
        width: 100% !important;
        height: 100% !important;
        z-index: 99 !important;
    }

    .asaf-grid-card img {
        display: block !important;
    }

    .asaf-slider-card {
        order: 1 !important;
        width: 100% !important;
        height: auto !important;
